# Environment variables for the Gatik Tulsiani portfolio.
# Copy this file to `.env.local` and fill in values. Never commit `.env.local`.
#
# All GitHub values are OPTIONAL. When absent, the GitHub section renders the
# committed fallback snapshot instead of live data (FR-GH-4, SM-9).

# GitHub read-only Personal Access Token (server-only; never exposed to client).
GITHUB_TOKEN=

# GitHub username whose public activity is surfaced.
GITHUB_USERNAME=

# Canonical site URL used for metadata / SEO (safe to expose).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
